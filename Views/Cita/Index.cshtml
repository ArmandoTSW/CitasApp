@model List<CitasApp.ViewModels.CitaViewModel>

@{
    ViewData["Title"] = "Agenda de citas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold text-primary">Agenda de citas médicas</h1>
            <p class="text-muted">Consulta las citas registradas con paciente, médico, fecha, hora y estado.</p>
        </div>

        <a class="btn btn-outline-primary" href="/Paciente">
            Ver pacientes
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Citas registradas</h5>
        </div>

        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Fecha</th>
                        <th>Hora</th>
                        <th>Paciente</th>
                        <th>Médico</th>
                        <th>Especialidad</th>
                        <th>Motivo</th>
                        <th>Estado</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var cita in Model)
                    {
                        <tr>
                            <td>@cita.Fecha.ToString("dd/MM/yyyy")</td>
                            <td>@cita.Hora.ToString("HH:mm")</td>
                            <td class="fw-semibold">@cita.NombrePaciente</td>
                            <td>@cita.NombreMedico</td>
                            <td>@cita.EspecialidadMedico</td>
                            <td>@cita.Motivo</td>
                            <td>
                                @if (cita.Estado == "Confirmada")
                                {
                                    <span class="badge bg-success">@cita.Estado</span>
                                }
                                else if (cita.Estado == "Pendiente")
                                {
                                    <span class="badge bg-warning text-dark">@cita.Estado</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">@cita.Estado</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>