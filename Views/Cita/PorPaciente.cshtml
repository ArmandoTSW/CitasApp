@model List<CitasApp.ViewModels.CitaViewModel>

@{
    ViewData["Title"] = "Citas por paciente";
}

<div class="container mt-4">
    <div class="mb-4">
        <h1 class="fw-bold text-primary">Citas de @ViewBag.NombrePaciente</h1>
        <p class="text-muted">Listado de citas médicas filtradas por paciente.</p>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Citas del paciente</h5>
        </div>

        <div class="card-body">
            @if (Model.Count == 0)
            {
                <div class="alert alert-info">
                    Este paciente no tiene citas registradas.
                </div>
            }
            else
            {
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Fecha</th>
                            <th>Hora</th>
                            <th>Médico</th>
                            <th>Especialidad</th>
                            <th>Motivo</th>
                            <th>Estado</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var cita in Model)
                        {
                            <tr>
                                <td>@cita.Fecha.ToString("dd/MM/yyyy")</td>
                                <td>@cita.Hora.ToString("HH:mm")</td>
                                <td class="fw-semibold">@cita.NombreMedico</td>
                                <td>@cita.EspecialidadMedico</td>
                                <td>@cita.Motivo</td>
                                <td>
                                    @if (cita.Estado == "Confirmada")
                                    {
                                        <span class="badge bg-success">@cita.Estado</span>
                                    }
                                    else if (cita.Estado == "Pendiente")
                                    {
                                        <span class="badge bg-warning text-dark">@cita.Estado</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">@cita.Estado</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            <div class="mt-4">
                <a class="btn btn-secondary" href="/Paciente">
                    Volver a pacientes
                </a>

                <a class="btn btn-outline-primary" href="/Cita">
                    Ver agenda completa
                </a>
            </div>
        </div>
    </div>
</div>